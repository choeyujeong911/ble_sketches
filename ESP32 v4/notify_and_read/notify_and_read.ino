// SSD1306용 16bit RGB bitmap 출력 함수
void drawRGBBitmapMono(int16_t x, int16_t y, const uint16_t* bitmap, int16_t w, int16_t h) {
  for (int16_t j = 0; j < h; j++) {
    for (int16_t i = 0; i < w; i++) {
      uint16_t color = pgm_read_word(&bitmap[j * w + i]);

      if (color != 0x0000) {
        display.drawPixel(x + i, y + j, SSD1306_WHITE);
      }
    }
  }
}

void drawScreen() {
  display.clearDisplay();

  // logo
  drawRGBBitmapMono(10, 12, image_logo_pixels, 24, 39);

  // val2: writeState 기반 0/1
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setTextWrap(false);
  display.setCursor(98, 40);
  display.print(writeValue);

  // Write_bg
  display.fillRect(87, 25, 33, 11, SSD1306_WHITE);

  // Write
  display.setTextColor(SSD1306_BLACK);
  display.setTextSize(1);
  display.setCursor(89, 27);
  display.print("Write");

  // led_bright: val2 == 1일 때만 표시
  if (writeValue == 1) {
    drawRGBBitmapMono(100, 11, image_led_bright_pixels, 6, 7);
  }

  // led: 항상 표시
  drawRGBBitmapMono(99, 10, image_led_1_pixels, 8, 12);

  // val1: notifyState 그대로 ON/OFF
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  if (notifyState == "ON") {
    display.setCursor(49, 40);
  } else {
    display.setCursor(44, 40);
  }
  display.print(notifyState);

  // Notify_bg
  display.fillRect(41, 25, 39, 11, SSD1306_WHITE);

  // Notify
  display.setTextColor(SSD1306_BLACK);
  display.setTextSize(1);
  display.setCursor(43, 27);
  display.print("Notify");

  // btn_pushed: 항상 표시
  drawRGBBitmapMono(52, 16, image_btn_pushed_pixels, 17, 6);

  // btn: notifyState == OFF일 때만 표시
  if (notifyState == "OFF") {
    drawRGBBitmapMono(55, 12, image_btn_1_pixels, 11, 6);
  }

  display.display();
}

// 앱에서 값을 WRITE했을 때 실행됨
class WriteCallback : public BLECharacteristicCallbacks {
  void onWrite(BLECharacteristic* characteristic) {
    String value = characteristic->getValue();

    if (value.length() > 0) {
      Serial.print("받은 값: ");
      Serial.println(value);

      if (value == "1") {
        writeState = "ON";
        writeValue = 1;
        Serial.println("Write: ON");
      } else if (value == "0") {
        writeState = "OFF";
        writeValue = 0;
        Serial.println("Write: OFF");
      } else {
        Serial.println("알 수 없는 값");
        return;
      }

      drawScreen();
    }
  }
};

void setup() {
  Serial.begin(9600);

  pinMode(BTN_PIN, INPUT);

  Serial.println("START");

  Wire.begin();

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("SSD1306 init failed");
    while (true);
  }

  drawScreen();

  BLEDevice::init("ESP32_BleTest");

  server = BLEDevice::createServer();

  BLEService* bleService = server->createService(SVC_UUID);

  btnCharacteristic = bleService->createCharacteristic(
    BTN_CHA_UUID,
    BLECharacteristic::PROPERTY_READ |
    BLECharacteristic::PROPERTY_NOTIFY
  );

  btnCharacteristic->addDescriptor(new BLE2902());
  btnCharacteristic->setValue("OFF");

  writeCharacteristic = bleService->createCharacteristic(
    WRITE_CHA_UUID,
    BLECharacteristic::PROPERTY_WRITE
  );

  writeCharacteristic->setCallbacks(new WriteCallback());
  writeCharacteristic->setValue("0");

  bleService->start();

  BLEAdvertising* advertising = BLEDevice::getAdvertising();
  advertising->addServiceUUID(SVC_UUID);
  advertising->setScanResponse(true);
  advertising->start();

  Serial.println("BLE service ready");
}

void loop() {
  bool connected = server->getConnectedCount() > 0;

  int currentButtonState = digitalRead(BTN_PIN);

  if (currentButtonState != lastButtonState) {
    if (currentButtonState == HIGH) {
      notifyState = "ON";
      btnCharacteristic->setValue("ON");

      if (connected) {
        btnCharacteristic->notify();
      }

      Serial.println("Notify: ON");
    } else {
      notifyState = "OFF";
      btnCharacteristic->setValue("OFF");

      if (connected) {
        btnCharacteristic->notify();
      }

      Serial.println("Notify: OFF");
    }

    drawScreen();
    lastButtonState = currentButtonState;
  }

  if (!connected && wasConnected) {
    Serial.println("Disconnected");
    BLEDevice::startAdvertising();
  }

  wasConnected = connected;

  delay(50);
}